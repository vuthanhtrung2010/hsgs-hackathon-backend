# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Canvas API Configuration
CANVAS_API_URL="https://your-canvas-instance.com/api/v1"
CANVAS_API_KEY="your_canvas_api_token"
CANVAS_COURSE_ID="your_course_id"

# Server Configuration
PORT=3000

# Environment
NODE_ENV="development"

# Logging Configuration
# LOG_LEVEL can be: DEBUG, INFO, WARN, ERROR, FATAL
# DEBUG: Shows all logs including API calls and database operations
# INFO: Shows general information, sync operations, and important events
# WARN: Shows warnings and potential issues
# ERROR: Shows errors only
# FATAL: Shows only fatal/critical errors
LOG_LEVEL="INFO"
